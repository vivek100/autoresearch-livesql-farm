	template_format VARCHAR NOT NULL, 
	template NUMERIC NOT NULL, 
	invocation_parameters NUMERIC NOT NULL, 
	tools JSON, 
	response_format JSON, 
	model_provider VARCHAR NOT NULL, 
	model_name VARCHAR NOT NULL, 
